{
  "version": 2,
  "buildCommand": "cp -f frontend/index.html frontend/public/index.html && echo 'BUILD_TS=$(date +%s%N)' >> frontend/public/index.html",
  "outputDirectory": "frontend/public",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "env": {
    "BUILD_TIMESTAMP": "@now"
  }
}